{
  "name": "blockly-repo",
  "version": "0.0.0",
  "description": "Monorepo for blockly and related packages",
  "keywords": [
    "blockly"
  ],
  "homepage": "https://blockly.com",
  "bugs": {
    "url": "https://github.com/RaspberryPiFoundation/blockly/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RaspberryPiFoundation/blockly.git"
  },
  "license": "Apache-2.0",
  "author": "Raspberry Pi Foundation",
  "private": true,
  "workspaces": [
    "packages/blockly",
    "packages/docs",
    "packages/plugins/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "10.5.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-mocha": "^11.3.0",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0"
  },
  "scripts": {
    "test": "npm run test --ws --if-present",
    "lint": "npm run lint --ws --if-present",
    "lint:fix": "npm run lint:fix --ws --if-present",
    "build": "npm run package --workspace=blockly && npm run build --ws --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "patch-package"
  }
}